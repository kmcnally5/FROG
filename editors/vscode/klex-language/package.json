{
  "name": "klex-language",
  "displayName": "kLex Language Support",
  "description": "Syntax highlighting for .lex files (kLex interpreter)",
  "version": "0.5.0",
  "publisher": "klex",
  "engines": { "vscode": "^1.60.0" },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [{
      "id": "klex",
      "aliases": ["kLex", "klex"],
      "extensions": [".lex"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "klex",
      "scopeName": "source.klex",
      "path": "./syntaxes/klex.tmLanguage.json"
    }]
  }
}
