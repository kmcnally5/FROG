{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "kLex",
  "scopeName": "source.klex",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#moduleAccess"
    },
    {
      "include": "#functionCalls"
    },
    {
      "include": "#self"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#rawStrings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.klex",
          "match": "//.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.klex",
          "match": "\\b(if|else|while|for|in|return|break|continue|switch|case|default|select)\\b"
        },
        {
          "name": "keyword.declaration.klex",
          "match": "\\bfn\\b"
        },
        {
          "match": "\\bfn\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": {
              "name": "entity.name.function.declaration.klex"
            }
          }
        },
        {
          "name": "keyword.declaration.klex",
          "match": "\\b(struct|enum|import|as|let|const)\\b"
        }
      ]
    },
    "moduleAccess": {
      "patterns": [
        {
          "name": "variable.other.module.klex",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\.)"
        }
      ]
    },
    "functionCalls": {
      "patterns": [
        {
          "name": "entity.name.function.klex",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\()"
        }
      ]
    },
    "self": {
      "patterns": [
        {
          "name": "variable.language.klex",
          "match": "\\bself\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.klex",
          "match": "\\b(null|true|false)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.klex",
          "match": "\\b(__version__|_aesDecrypt|_aesEncrypt|_base64Decode|_base64Encode|_base64UrlDecode|_base64UrlEncode|_bcryptHash|_bcryptVerify|_constantTimeEquals|_csvFirstRowCols|_csvFormat|_csvFormatDelim|_csvHasRows|_csvParse|_csvParseDelim|_csvParseHeaders|_csvStream|_deflateCompress|_deflateDecompress|_fsAppend|_fsChmod|_fsCopy|_fsExists|_fsListDir|_fsLstat|_fsMap|_fsMkdir|_fsMkdirAll|_fsRead|_fsReadChunk|_fsReadDir|_fsReadlink|_fsRemove|_fsRemoveAll|_fsRename|_fsStat|_fsSymlink|_fsTmpDir|_fsTmpFile|_fsWrite|_gzipCompress|_gzipDecompress|_hmacSha256|_hmacSha512|_httpDo|_httpServe|_md5|_osArgs|_osCwd|_osExit|_osGetenv|_osHostname|_osPid|_osSetenv|_processExec|_processRun|_processShell|_randomBytes|_regexFind|_regexFindAll|_regexGroups|_regexGroupsAll|_regexMatch|_regexReplace|_regexReplaceAll|_regexSplit|_sha256|_sha512|_timeFields|_timeFormat|_timeNanos|_timeNow|_timeParse|_tsvFormat|_tsvParse|_urlDecode|_urlEncode|_uuid|abs|accordion|acos|appendFile|arc|asin|assert|async|atan|atan2|atomicAdd|atomicCAS|atomicFloatArray|atomicHashAdd|atomicHashCAS|atomicHashIncr|atomicIntArray|atomicLoad|atomicStore|await|background|barChart|blendMode|button|cancel|ceil|channel|checkbox|circle|close|colorPicker|color_bg_black|color_bg_blue|color_bg_cyan|color_bg_green|color_bg_magenta|color_bg_red|color_bg_white|color_bg_yellow|color_black|color_blue|color_bold|color_cyan|color_dim|color_green|color_magenta|color_red|color_reset|color_underline|color_white|color_yellow|colorize|concat|concurrentHash|constrain|contextMenu|cos|delete|dnsLookup|drawImage|drawParticles|dropdown|droppedFiles|e|elapsedTime|ellipse|endsWith|env|error|exec|exp|fill|filter|float|floor|fmod|fontCharHeight|fontCharWidth|format|frameCount|frameRate|getTypedChars|gradient|hasKey|hsl|image|indexOf|input|int|isError|join|keyDown|keyPressed|keys|label|len|lerp|line|lineChart|list|listMulti|loadFont|loadImage|log|log10|log2|lower|makeArray|makeTheme|map|max|min|mod|modal|mouseClicked|mouseDown|mouseRightClicked|mouseRightDown|mouseScrollX|mouseScrollY|mouseX|mouseY|netClose|netRead|netWrite|noFill|noStroke|numericStepper|parallelArrayForEach|parallelArrayMap|parallelArrayReduce|parallelArrayUpdate|pi|pieChart|point|polygon|pop|popClip|popMatrix|pow|print|println|progressBar|push|pushClip|pushMatrix|radio|rand|randInt|range|readFile|rect|recv|recvNonBlock|reduce|remap|replace|rotate|round|roundedRect|safe|scale|scrollArea|send|shuffle|sin|sleep|slice|slider|sort|sortBy|sparkline|split|splitter|sqrt|startsWith|str|stroke|strokeWeight|substr|table|tabs|tan|tcpDial|tcpListen|text|textArea|textFont|textInput|textWidth|toast|toggle|tooltip|translate|treeView|triangle|trim|type|uiBegin|uiBeginCol|uiBeginRow|uiColAdvance|uiColW|uiColX|uiColY|uiEnd|uiGetFocus|uiNextFieldID|uiResetFont|uiRowAdvance|uiRowH|uiRowX|uiRowY|uiSetFocus|uiSetFont|uiTheme|upper|values|winHeight|winWidth|window|writeFile)\\b(?=\\s*\\()"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.klex",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.klex",
              "match": "\\\\(?:[nrtb\"\\\\{]|x[0-9a-fA-F]{2})"
            },
            {
              "name": "meta.embedded.klex",
              "begin": "(?<!\\\\)\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.section.embedded.begin.klex"
                }
              },
              "endCaptures": {
                "0": {
                  "name": "punctuation.section.embedded.end.klex"
                }
              },
              "patterns": [
                {
                  "include": "#keywords"
                },
                {
                  "include": "#constants"
                },
                {
                  "include": "#builtins"
                },
                {
                  "include": "#numbers"
                },
                {
                  "include": "#operators"
                }
              ]
            }
          ]
        }
      ]
    },
    "rawStrings": {
      "patterns": [
        {
          "name": "string.quoted.other.klex",
          "begin": "`",
          "end": "`"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.klex",
          "match": "\\b[0-9]+(?:\\.[0-9]+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.klex",
          "match": "(==|!=|<=|>=|&&|\\|>|\\|\\||\\.\\.\\.|[+\\-*/<>!%]|(?<![=<>!])=(?!=))"
        }
      ]
    }
  }
}
